# Coral Stack Environment Configuration
# Copy this file to .env and fill in the values

# PostgreSQL Configuration
POSTGRES_USER=coral
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=coral
DATABASE_URL=postgres://coral:your_secure_password_here@localhost:5432/coral

# Hypixel API Key
HYPIXEL_API_KEY=your_hypixel_api_key

# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token
OWNER_IDS=

# Discord Channel IDs (optional)
BLACKLIST_CHANNEL_ID=
MOD_CHANNEL_ID=
REVIEW_FORUM_ID=
EVIDENCE_FORUM_ID=


# API Configuration
API_PORT=8000

# Internal API Key (used by coral-bot to authenticate with coral-api)
INTERNAL_API_KEY=your_internal_api_key_here

# Bot API Configuration (CORAL_API_URL defaults to http://localhost:8000)
CORAL_API_URL=http://localhost:8000

# Logging Level (trace, debug, info, warn, error)
RUST_LOG=info
